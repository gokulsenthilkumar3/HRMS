# ==========================================================
# HRMS Environment Variables
# Copy to .env and fill in your values
# ==========================================================

# --- Database ---
# PostgreSQL connection string (Supabase / Render / local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hrms_db?schema=public"

# --- JWT Auth ---
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-min-64-chars"
JWT_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

# --- App ---
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# --- Azure AD SSO (optional — for enterprise SSO) ---
AZURE_AD_TENANT_ID=""
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""

# --- Email (optional — for leave approval notifications) ---
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@company.com"

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_NAME="HRMS"
NEXT_PUBLIC_APP_VERSION="2.0.0"
