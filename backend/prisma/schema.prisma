generator client {
  provider = "prisma-client-js"
}

// Production: PostgreSQL (Render / Supabase)
// Local dev:  Set DATABASE_URL in .env to a local PostgreSQL or Supabase URL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum AssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum MaintenanceStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model User {
  id                String         @id @default(uuid())
  email             String         @unique
  passwordHash      String?        // bcrypt hash — null for SSO-only users
  fullName          String
  role              UserRole       @default(USER)
  azureId           String?        @unique // nullable: local-auth users have no azureId
  department        String?
  designation       String?        // job title / designation
  employeeId        String?        @unique // human-readable EMP-XXXX
  employeeCode      String?        @unique // system-generated code
  phone             String?
  gender            Gender?        @default(PREFER_NOT_TO_SAY)
  employmentType    EmploymentType @default(FULL_TIME)
  hireDate          DateTime?
  probationEndDate  DateTime?
  performanceRating Int?           // 1-5
  dateOfBirth       DateTime?
  address           String?
  city              String?
  state             String?
  country           String?        @default("India")
  avatarUrl         String?
  isActive          Boolean        @default(true)
  managerId         String?        // self-referencing for org hierarchy
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  manager           User?          @relation("Manages", fields: [managerId], references: [id])
  reportees         User[]         @relation("Manages")
  assignments       AssetAssignment[]
  auditLogs         AuditLog[]
  tickets           HelpdeskTicket[]
  leaveRequests     LeaveRequest[]
  payslips          Payslip[]
  attendanceLogs    AttendanceLog[]
  ticketComments    TicketComment[]
  roomBookings      RoomBooking[]
  deskBookings      DeskBooking[]
  purchaseRequests  PurchaseRequest[]
  assignedTasks     WorkflowTask[]  @relation("AssignedTo")
  targetedTasks     WorkflowTask[]  @relation("TargetUser")
  conductedAudits   ComplianceAudit[]
  refreshTokens     RefreshToken[]

  @@index([email])
  @@index([department])
  @@index([managerId])
}

model Asset {
  id            String      @id @default(uuid())
  tagId         String      @unique
  serialNumber  String      @unique
  modelName     String
  typeId        String
  locationId    String
  status        AssetStatus @default(AVAILABLE)
  purchasePrice Float
  purchaseDate  DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  type        AssetType           @relation(fields: [typeId], references: [id])
  location    Location            @relation(fields: [locationId], references: [id])
  assignments AssetAssignment[]
  maintenance MaintenanceRecord[]
  tickets     HelpdeskTicket[]
  auditLogs   AuditLog[]
}

model AssetAssignment {
  id             String    @id @default(uuid())
  assetId        String
  userId         String
  assignedAt     DateTime  @default(now())
  returnedAt     DateTime?
  signatureBlob  String?
  conditionNotes String?

  asset Asset @relation(fields: [assetId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
}

model MaintenanceRecord {
  id              String              @id @default(uuid())
  assetId         String
  issueType       String
  description     String
  priority        MaintenancePriority @default(MEDIUM)
  status          MaintenanceStatus   @default(OPEN)
  scheduledDate   DateTime
  completedAt     DateTime?
  technicianNotes String?

  asset Asset @relation(fields: [assetId], references: [id])
}

model AssetType {
  id            String  @id @default(uuid())
  name          String  @unique
  lifespanYears Int
  assets        Asset[]
}

model Location {
  id           String        @id @default(uuid())
  name         String        @unique
  address      String
  assets       Asset[]
  meetingRooms MeetingRoom[]
  desks        Desk[]
}

model AuditLog {
  id                String   @id @default(uuid())
  action            String
  assetId           String?
  userId            String
  details           String
  timestamp         DateTime @default(now())
  blockHash         String?
  previousBlockHash String?

  user  User   @relation(fields: [userId], references: [id])
  asset Asset? @relation(fields: [assetId], references: [id])

  @@index([assetId, timestamp])
}

model HelpdeskTicket {
  id          String         @id @default(uuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  userId      String
  assetId     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user     User            @relation(fields: [userId], references: [id])
  asset    Asset?          @relation(fields: [assetId], references: [id])
  comments TicketComment[]
}

model CompanyUpdate {
  id      String   @id @default(uuid())
  title   String
  content String
  type    String
  author  String
  date    DateTime @default(now())
}

model LeaveRequest {
  id        String   @id @default(uuid())
  userId    String
  type      String
  startDate DateTime
  endDate   DateTime
  days      Int
  reason    String?  // reason for leave
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Payslip {
  id          String   @id @default(uuid())
  userId      String
  period      String
  basicSalary Float    @default(0)
  hra         Float    @default(0)
  allowances  Float    @default(0)
  deductions  Float    @default(0)
  taxAmount   Float    @default(0)
  netAmount   Float    @default(0)
  status      String   @default("PAID")
  date        DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Quote {
  id      String @id @default(uuid())
  content String
  author  String @default("Unknown")
}

model AttendanceLog {
  id       String    @id @default(uuid())
  userId   String
  date     DateTime  @default(now())
  clockIn  DateTime?
  clockOut DateTime?
  status   String    @default("PRESENT") // PRESENT, ABSENT, HALF_DAY, LEAVE, HOLIDAY, WFH
  notes    String?

  user User @relation(fields: [userId], references: [id])

  @@index([userId, date])
}

model TicketComment {
  id        String   @id @default(uuid())
  ticketId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id])
  author User           @relation(fields: [authorId], references: [id])
}

model MeetingRoom {
  id         String   @id @default(uuid())
  name       String   @unique
  capacity   Int
  locationId String
  status     String   @default("AVAILABLE")

  location Location      @relation(fields: [locationId], references: [id])
  bookings RoomBooking[]
}

model RoomBooking {
  id        String   @id @default(uuid())
  roomId    String
  userId    String
  startTime DateTime
  endTime   DateTime
  purpose   String?

  room MeetingRoom @relation(fields: [roomId], references: [id])
  user User        @relation(fields: [userId], references: [id])
}

model Desk {
  id         String   @id @default(uuid())
  label      String   @unique
  locationId String
  isHotDesk  Boolean  @default(true)
  status     String   @default("AVAILABLE")

  location Location      @relation(fields: [locationId], references: [id])
  bookings DeskBooking[]
}

model DeskBooking {
  id        String    @id @default(uuid())
  deskId    String
  userId    String
  date      DateTime
  startTime DateTime?
  endTime   DateTime?

  desk Desk @relation(fields: [deskId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model Vendor {
  id           String   @id @default(uuid())
  name         String   @unique
  contactEmail String?
  contactPhone String?
  website      String?

  purchaseRequests PurchaseRequest[]
}

model PurchaseRequest {
  id            String   @id @default(uuid())
  requestedById String
  vendorId      String?
  title         String
  description   String
  expectedCost  Float
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  requestedBy User    @relation(fields: [requestedById], references: [id])
  vendor      Vendor? @relation(fields: [vendorId], references: [id])
}

model WorkflowTask {
  id           String    @id @default(uuid())
  title        String
  type         String
  targetUserId String?
  assignedToId String
  status       String    @default("PENDING")
  dueDate      DateTime?
  createdAt    DateTime  @default(now())

  targetUser User? @relation("TargetUser", fields: [targetUserId], references: [id])
  assignedTo User  @relation("AssignedTo", fields: [assignedToId], references: [id])
}

model ComplianceAudit {
  id            String   @id @default(uuid())
  type          String
  targetId      String?
  conductedById String
  findings      String?
  status        String   @default("SCHEDULED")
  date          DateTime

  conductedBy User @relation(fields: [conductedById], references: [id])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  revoked   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Training & LMS
model TrainingCourse {
  id          String   @id @default(uuid())
  title       String
  description String?
  category    String
  durationHrs Int      @default(1)
  createdAt   DateTime @default(now())

  enrollments CourseEnrollment[]
}

model CourseEnrollment {
  id          String    @id @default(uuid())
  courseId    String
  userId      String
  status      String    @default("ENROLLED") // ENROLLED, IN_PROGRESS, COMPLETED
  progress    Int       @default(0) // 0-100
  completedAt DateTime?
  enrolledAt  DateTime  @default(now())

  course TrainingCourse @relation(fields: [courseId], references: [id])
}

// Performance Goals
model PerformanceGoal {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  targetDate  DateTime
  progress    Int      @default(0)
  status      String   @default("IN_PROGRESS") // IN_PROGRESS, ACHIEVED, MISSED
  cycle       String   // e.g. "Q3 FY2026"
  createdAt   DateTime @default(now())
}

// Recruitment Pipeline
model JobPosting {
  id          String       @id @default(uuid())
  title       String
  department  String
  location    String
  type        String       @default("FULL_TIME")
  description String?
  isActive    Boolean      @default(true)
  postedAt    DateTime     @default(now())

  applicants  Applicant[]
}

model Applicant {
  id          String   @id @default(uuid())
  jobId       String
  name        String
  email       String
  phone       String?
  resumeUrl   String?
  source      String   @default("Direct")
  stage       String   @default("SCREENING") // SCREENING, INTERVIEW, OFFER, JOINED, REJECTED
  rating      Int?     // 1-5
  notes       String?
  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  job JobPosting @relation(fields: [jobId], references: [id])
}
